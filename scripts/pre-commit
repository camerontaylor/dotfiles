#!/usr/bin/env zsh
# Auto-encrypt secrets before commit
# Runs on: git commit (pre-commit hook)

setopt extended_glob

SCRIPT_DIR=${0:A:h}

# Secret paths (plaintext gitignored, *.enc tracked)
local -a secret_patterns=(
    "zsh/env.d/9[0-9]_*"
    "zsh/rc.d/9[0-9]_*"
    "nvim/init/9[0-9]_*"
)

# Check if sops is available
if (( ! ${+commands[sops]} )); then
    print "warning: sops not found, skipping secret encryption"
    exit 0
fi

local encrypted=false

# Extract age public key from .sops.yaml (once, before loop)
local age_key=$(awk '/age:/{print $2}' $SCRIPT_DIR/../.sops.yaml 2>/dev/null)
if [[ -z $age_key ]]; then
    print "warning: no age key in .sops.yaml, run deploy.zsh first"
    exit 0
fi

for pattern in $secret_patterns[@]; do
    # Find plaintext files (excluding .enc files)
    for plaintext in $pattern~*.enc(N); do
        local enc_file="${plaintext}.enc"

        # Check if plaintext is newer than encrypted or encrypted doesn't exist
        if [[ ! -f $enc_file || $plaintext -nt $enc_file ]]; then
            print "Encrypting $plaintext -> $enc_file..."

            if sops --encrypt --age $age_key --input-type binary --output-type binary --config /dev/null --output $enc_file $plaintext 2>/dev/null; then
                git add $enc_file
                encrypted=true
                print "  ...done"
            else
                print "  ...failed to encrypt $plaintext"
                exit 1
            fi
        fi
    done
done

exit 0
